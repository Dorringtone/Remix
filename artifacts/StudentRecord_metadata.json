		"devdoc": {
			"details": "A smart contract for managing student academic records. Only the contract owner can add and update student records, while anyone can view student information.",
			"kind": "dev",
			"methods": {
				"addStudent(uint256,string,uint256,string,uint256)": {
					"details": "Adds a new student record. Only the owner can call this function.",
					"params": {
						"_age": "Student age",
						"_course": "Student course",
						"_id": "Student ID",
						"_marks": "Student marks",
						"_name": "Student name"
					}
				},
				"getAllStudentIds()": {
					"details": "Returns all student IDs stored in the contract."
				},
				"getStudent(uint256)": {
					"details": "Returns a student record by ID. Anyone can call this function.",
					"params": {
						"_id": "Student ID"
					}
				},
				"getStudentCount()": {
					"details": "Returns the total number of student records."
				},
				"studentExists(uint256)": {
					"details": "Checks whether a student exists.",
					"params": {
						"_id": "Student ID"
					}
				},
				"transferOwnership(address)": {
					"details": "Transfers ownership to another address. Only current owner can call this function.",
					"params": {
						"_newOwner": "Address of new owner"
					}
				},
				"updateStudent(uint256,string,uint256,string,uint256)": {
					"details": "Updates an existing student record. Only the owner can call this function.",
					"params": {
						"_age": "Updated student age",
						"_course": "Updated student course",
						"_id": "Student ID",
						"_marks": "Updated student marks",
						"_name": "Updated student name"
					}
				}
			},
