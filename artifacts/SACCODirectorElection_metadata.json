		"devdoc": {
			"details": "A smart contract for SACCO director elections. The admin registers candidates and qualified delegates. Delegates can vote once per position during the active election period.",
			"kind": "dev",
			"methods": {
				"closeElection()": {
					"details": "Close election manually."
				},
				"deactivateCandidate(uint256)": {
					"details": "Deactivate a candidate before election opens."
				},
				"getAllPositions()": {
					"details": "Returns all known positions in the election."
				},
				"getCandidate(uint256)": {
					"details": "Returns candidate details."
				},
				"getCandidatesByPosition(string)": {
					"details": "Returns all candidate IDs for a given position."
				},
				"getPositionResults(string)": {
					"details": "Returns full results for a specific position."
				},
				"hasDelegateVotedForPosition(address,string)": {
					"details": "Returns whether a delegate has voted for a specific position."
				},
				"openElection(uint256)": {
					"details": "Open the election for a given number of minutes."
				},
				"registerCandidate(string,string,string)": {
					"details": "Register a candidate for a SACCO position. Example positions: Chairperson, Treasurer, Director"
				},
				"registerDelegate(address,string,string)": {
					"details": "Register a qualified delegate who can vote."
				},
				"timeLeft()": {
					"details": "Returns time left in seconds."
				},
				"transferAdmin(address)": {
					"details": "Transfer admin role to another address."
				},
				"vote(uint256)": {
					"details": "Cast one vote for one candidate in a given position. A delegate can vote only once per position."
				},
				"winnerDetails(string)": {
					"details": "Returns winner details for a given position."
				},
				"winningCandidate(string)": {
					"details": "Returns the winning candidate ID for a given position. Can only be called after election closes or deadline passes."
				}
			},
			"title": "SACCODirectorElection",
			"version": 1
		},
